{
  "manifest_version": 3,
  "name": "Billy Blocksi Local",
  "version": "1.0",
  "permissions": [
    "declarativeNetRequest",
    "storage",
    "unlimitedStorage",
    "alarms",
    "tabs"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "declarative_net_request": {
    "rule_resources": [{
      "id": "ruleset_1",
      "enabled": true,
      "path": "rules.json"
    }]
  }
}
"externally_connectable": {
  "ids": ["YOUR_TEACHER_EXTENSION_ID_HERE"]
}
